<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="page-header">
    <h1 class="page-title">👥 <span><%= title %></span></h1>
    <a href="/members" class="btn btn-secondary">← กลับ</a>
  </div>

  <% if (error && error.length > 0) { %><div class="alert alert-danger">⚠️ <%= error[0] %></div><% } %>

  <div class="card" style="max-width:500px;">
    <form method="POST" action="<%= member ? '/members/' + member._id : '/members' %>">
      <div class="form-group">
        <label class="form-label">ชื่อ-นามสกุล *</label>
        <input type="text" name="name" class="form-control" value="<%= member ? member.name : '' %>" required>
      </div>
      <div class="form-group">
        <label class="form-label">เบอร์โทรศัพท์ *</label>
        <input type="text" name="phone" class="form-control" value="<%= member ? member.phone : '' %>" required>
      </div>
      <div class="form-group">
        <label class="form-label">อีเมล</label>
        <input type="email" name="email" class="form-control" value="<%= member ? member.email || '' : '' %>">
      </div>
      <div class="form-group">
        <label class="form-label">วันเกิด</label>
        <input type="date" name="birthDate" class="form-control" value="<%= member && member.birthDate ? member.birthDate.toISOString().split('T')[0] : '' %>">
      </div>
      <% if (member) { %>
      <div class="form-group">
        <label class="form-label">สถานะ</label>
        <select name="isActive" class="form-control">
          <option value="true" <%= member.isActive ? 'selected' : '' %>>ใช้งาน</option>
          <option value="false" <%= !member.isActive ? 'selected' : '' %>>ปิดใช้งาน</option>
        </select>
      </div>
      <% } %>
      <div style="display:flex; gap:10px; margin-top:8px;">
        <button type="submit" class="btn btn-primary">💾 บันทึก</button>
        <a href="/members" class="btn btn-secondary">ยกเลิก</a>
      </div>
    </form>
  </div>
</div>
</body></html>

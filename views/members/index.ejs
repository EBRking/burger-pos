<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="page-header">
    <h1 class="page-title">👥 <span>จัดการสมาชิก</span></h1>
    <a href="/members/new" class="btn btn-primary">➕ เพิ่มสมาชิก</a>
  </div>

  <% if (success && success.length > 0) { %><div class="alert alert-success">✅ <%= success[0] %></div><% } %>
  <% if (error && error.length > 0) { %><div class="alert alert-danger">⚠️ <%= error[0] %></div><% } %>

  <div class="card">
    <form method="GET" style="display:flex; gap:10px; margin-bottom:16px;">
      <input type="text" name="search" class="form-control" placeholder="ค้นหาชื่อ, เบอร์, รหัสสมาชิก..." value="<%= search %>" style="max-width:300px;">
      <button type="submit" class="btn btn-primary">🔍 ค้นหา</button>
      <% if (search) { %><a href="/members" class="btn btn-secondary">✕ ล้าง</a><% } %>
    </form>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>รหัสสมาชิก</th><th>ชื่อ</th><th>เบอร์โทร</th><th>แต้ม</th><th>ยอดซื้อรวม</th><th>สถานะ</th><th>จัดการ</th></tr>
        </thead>
        <tbody>
          <% members.forEach(m => { %>
          <tr>
            <td><span class="badge badge-primary"><%= m.memberCode %></span></td>
            <td style="font-weight:600;"><%= m.name %></td>
            <td><%= m.phone %></td>
            <td><span style="color:var(--secondary); font-weight:600;">⭐ <%= m.points %></span></td>
            <td style="font-weight:600;">฿<%= m.totalSpent.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
            <td><span class="badge <%= m.isActive ? 'badge-success' : 'badge-danger' %>"><%= m.isActive ? 'ใช้งาน' : 'ปิดใช้' %></span></td>
            <td>
              <a href="/members/<%= m._id %>/edit" class="btn btn-sm btn-secondary">✏️ แก้ไข</a>
              <form method="POST" action="/members/<%= m._id %>/delete" style="display:inline;" onsubmit="return confirm('ยืนยันการลบ?')">
                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (members.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#999; padding:20px;">ไม่พบข้อมูลสมาชิก</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body></html>

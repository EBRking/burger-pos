<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="page-header">
    <h1 class="page-title">👤 <span>รายงานพนักงาน</span></h1>
    <a href="/reports" class="btn btn-secondary">← กลับ</a>
  </div>

  <div class="card">
    <form method="GET" style="display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap;">
      <div><label style="font-size:0.78rem; color:#999;">จากวันที่</label>
        <input type="date" name="dateFrom" class="form-control" value="<%= dateFrom %>"></div>
      <div><label style="font-size:0.78rem; color:#999;">ถึงวันที่</label>
        <input type="date" name="dateTo" class="form-control" value="<%= dateTo %>"></div>
      <button type="submit" class="btn btn-primary">🔍 ดูรายงาน</button>
    </form>
  </div>

  <div style="display:grid; grid-template-columns:2fr 1fr; gap:20px;">
    <div class="card">
      <div class="card-header"><span class="card-title">🏆 ผลการทำงานพนักงาน</span></div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>อันดับ</th><th>ชื่อพนักงาน</th><th>บทบาท</th><th>จำนวนออเดอร์</th><th>ยอดขายรวม</th></tr></thead>
          <tbody>
            <% empStats.forEach((e, i) => { %>
            <tr>
              <td><span class="badge <%= i === 0 ? 'badge-warning' : 'badge-primary' %>"><%= i+1 %></span></td>
              <td style="font-weight:600;"><%= e.name %></td>
              <td><span class="badge <%= e.role === 'owner' ? 'badge-warning' : 'badge-info' %>"><%= e.role === 'owner' ? '🔑 เจ้าของ' : '👷 พนักงาน' %></span></td>
              <td><%= e.orders %> ออเดอร์</td>
              <td style="font-weight:700; color:var(--primary);">฿<%= e.revenue.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
            </tr>
            <% }) %>
            <% if (empStats.length === 0) { %><tr><td colspan="5" style="text-align:center;color:#999;padding:20px;">ไม่มีข้อมูล</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><span class="card-title">📊 ยอดขายแต่ละคน</span></div>
      <canvas id="empChart" height="220"></canvas>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const empData = <%- JSON.stringify(empStats) %>;
new Chart(document.getElementById('empChart').getContext('2d'), {
  type: 'bar',
  data: {
    labels: empData.map(e => e.name),
    datasets: [{ label: 'ยอดขาย (฿)', data: empData.map(e => e.revenue), backgroundColor: '#D2691E', borderRadius: 6 }]
  },
  options: { responsive: true, indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
});
</script>
</body></html>

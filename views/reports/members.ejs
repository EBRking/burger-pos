<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="page-header">
    <h1 class="page-title">👥 <span>รายงานสมาชิก</span></h1>
    <a href="/reports" class="btn btn-secondary">← กลับ</a>
  </div>

  <div class="stat-grid" style="grid-template-columns: repeat(3, 1fr);">
    <div class="stat-card green"><div class="stat-icon">👥</div>
      <div><div class="stat-value"><%= totalMembers %></div><div class="stat-label">สมาชิกทั้งหมด</div></div></div>
    <div class="stat-card orange"><div class="stat-icon">⭐</div>
      <div><div class="stat-value"><%= totalPoints.toLocaleString('th-TH') %></div><div class="stat-label">แต้มสะสมรวม</div></div></div>
    <div class="stat-card"><div class="stat-icon">💰</div>
      <div><div class="stat-value">฿<%= members.reduce((s,m) => s+m.totalSpent, 0).toLocaleString('th-TH', {minimumFractionDigits:2}) %></div><div class="stat-label">ยอดซื้อรวมทุกคน</div></div></div>
  </div>

  <div class="card">
    <div class="card-header"><span class="card-title">🏆 Top 10 สมาชิก VIP (ยอดซื้อสูงสุด)</span></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>อันดับ</th><th>รหัสสมาชิก</th><th>ชื่อ</th><th>เบอร์โทร</th><th>แต้มสะสม</th><th>ยอดซื้อรวม</th></tr></thead>
        <tbody>
          <% topMembers.forEach((m, i) => { %>
          <tr>
            <td><span class="badge <%= i === 0 ? 'badge-warning' : i < 3 ? 'badge-info' : 'badge-primary' %>"><%= i+1 %></span></td>
            <td><span class="badge badge-primary"><%= m.memberCode %></span></td>
            <td style="font-weight:600;"><%= m.name %></td>
            <td><%= m.phone %></td>
            <td><span style="color:var(--secondary); font-weight:600;">⭐ <%= m.points %></span></td>
            <td style="font-weight:700; color:var(--primary);">฿<%= m.totalSpent.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
          </tr>
          <% }) %>
          <% if (members.length === 0) { %><tr><td colspan="6" style="text-align:center;color:#999;padding:20px;">ไม่มีสมาชิก</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body></html>

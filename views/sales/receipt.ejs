<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <div class="page-header">
    <h1 class="page-title">🧾 <span>ใบเสร็จรับเงิน</span></h1>
    <div style="display:flex; gap:8px;">
      <button onclick="window.print()" class="btn btn-secondary">🖨️ พิมพ์</button>
      <a href="/sales/pos" class="btn btn-primary">🛒 ขายต่อ</a>
      <a href="/sales" class="btn btn-secondary">← กลับ</a>
    </div>
  </div>

  <% if (success && success.length > 0) { %><div class="alert alert-success">✅ <%= success[0] %></div><% } %>

  <div class="receipt">
    <div class="receipt-header">
      <div style="font-size:2rem;">🍔</div>
      <h2 style="color:var(--primary-dark); margin:4px 0;">Burger POS</h2>
      <p style="color:#999; font-size:0.8rem;">ใบเสร็จรับเงิน</p>
      <p style="font-size:0.85rem; font-weight:600; margin-top:8px;"><%= sale.saleCode %></p>
      <p style="font-size:0.78rem; color:#999;"><%= new Date(sale.createdAt).toLocaleString('th-TH') %></p>
    </div>

    <div style="margin-bottom:12px; font-size:0.82rem;">
      <div class="receipt-row"><span>พนักงาน:</span><span><%= sale.employee ? sale.employee.name : '-' %></span></div>
      <% if (sale.member) { %>
      <div class="receipt-row"><span>สมาชิก:</span><span><%= sale.member.name %> (<%= sale.member.memberCode %>)</span></div>
      <% } else { %>
      <div class="receipt-row"><span>ลูกค้า:</span><span>ทั่วไป</span></div>
      <% } %>
    </div>

    <div style="border-top:1px dashed var(--border); border-bottom:1px dashed var(--border); padding:10px 0; margin-bottom:10px;">
      <% sale.items.forEach(item => { %>
      <div class="receipt-row">
        <span><%= item.productName %> x<%= item.quantity %></span>
        <span>฿<%= item.subtotal.toLocaleString('th-TH', {minimumFractionDigits:2}) %></span>
      </div>
      <% }) %>
    </div>

    <div class="receipt-total">
      <div class="receipt-row"><span>ยอดรวม:</span><span>฿<%= sale.subtotal.toLocaleString('th-TH', {minimumFractionDigits:2}) %></span></div>
      <% if (sale.discountAmount > 0) { %>
      <div class="receipt-row" style="color:var(--danger);">
        <span>ส่วนลด<%= sale.promotionName ? ' (' + sale.promotionName + ')' : '' %>:</span>
        <span>-฿<%= sale.discountAmount.toLocaleString('th-TH', {minimumFractionDigits:2}) %></span>
      </div>
      <% } %>
      <div class="receipt-row" style="font-size:1.1rem; font-weight:700; color:var(--primary); margin-top:6px;">
        <span>ยอดสุทธิ:</span><span>฿<%= sale.total.toLocaleString('th-TH', {minimumFractionDigits:2}) %></span>
      </div>
      <div class="receipt-row" style="margin-top:6px;">
        <span>ช่องทาง:</span>
        <span><%= sale.paymentMethod === 'cash' ? '💵 เงินสด' : sale.paymentMethod === 'transfer' ? '📱 โอนเงิน' : '💳 บัตรเครดิต' %></span>
      </div>
      <% if (sale.paymentMethod === 'cash') { %>
      <div class="receipt-row"><span>รับเงินมา:</span><span>฿<%= sale.amountPaid.toLocaleString('th-TH', {minimumFractionDigits:2}) %></span></div>
      <div class="receipt-row"><span>เงินทอน:</span><span>฿<%= sale.change.toLocaleString('th-TH', {minimumFractionDigits:2}) %></span></div>
      <% } %>
    </div>

    <% if (sale.note) { %>
    <div style="margin-top:10px; padding:8px; background:#FFF8F0; border-radius:6px; font-size:0.8rem;">
      📝 หมายเหตุ: <%= sale.note %>
    </div>
    <% } %>

    <div style="text-align:center; margin-top:16px; color:#999; font-size:0.78rem;">
      ขอบคุณที่ใช้บริการ 🍔<br>กลับมาอีกนะครับ/ค่ะ
    </div>

    <div style="margin-top:16px; text-align:center;">
      <span class="badge <%= sale.status === 'completed' ? 'badge-success' : 'badge-danger' %>" style="font-size:0.85rem; padding:6px 16px;">
        <%= sale.status === 'completed' ? '✅ ชำระแล้ว' : '❌ ยกเลิก' %>
      </span>
    </div>
  </div>
</div>
<style>
@media print {
  .sidebar, .page-header, .alert { display: none !important; }
  .main-content { margin-left: 0 !important; }
  .receipt { box-shadow: none; }
}
</style>
</body></html>
